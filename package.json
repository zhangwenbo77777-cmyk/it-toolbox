{
  "name": "it-toolbox",
  "version": "1.1.0-beta",
  "description": "IT工具箱 - 系统监控",
  "main": "main.js",
  "author": "KS",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "systeminformation": "^5.21.0",
    "node-notifier": "^10.0.1"
  },
  "build": {
    "appId": "com.ks.it-toolbox",
    "productName": "IT工具箱",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}